# Satellite Inference Pipeline - .gitignore

# ============================================================================
# Data & Input Files
# ============================================================================
# Input directory with incoming images
data/
data/incoming/
data/**/*.tif
data/**/*.tiff
data/**/*.jp2
data/**/*.img
data/**/*.TIF
data/**/*.TIFF
data/**/*.JP2
data/**/*.IMG

# ============================================================================
# Output & Artifacts
# ============================================================================
# All output artifacts
artifacts/
artifacts/**/*
!artifacts/.gitkeep

# Success outputs
artifacts/success/
artifacts/success/**/*

# Failure outputs
artifacts/failure/
artifacts/failure/**/*

# Combined outputs (deprecated but keep ignored)
artifacts/combined/
artifacts/combined/**/*

# Temporary files
artifacts/tmp/
artifacts/tmp/**/*

# Health status (runtime data)
artifacts/health/
artifacts/health/**/*

# Per-image logs (in artifacts)
artifacts/logs/
artifacts/logs/**/*

# ============================================================================
# State & Cache Files
# ============================================================================
# Job queue state
state/
state/**/*
!state/.gitkeep

# Queue persistence
state/queue.json
state/queue.json.*

# Tile cache
state/tile_cache/
state/tile_cache/**/*

# Quarantine (failed jobs)
state/quarantine/
state/quarantine/**/*

# ============================================================================
# Logs
# ============================================================================
# Pipeline logs
logs/
logs/**/*
!logs/.gitkeep

# Per-image logs
logs/pipeline/
logs/pipeline/**/*
logs/pipeline/images/
logs/pipeline/images/**/*

# ============================================================================
# Model Files (usually large, version-controlled separately)
# ============================================================================
# Model weights (ignored to keep repository small)
models/
models/**/*
!models/.gitkeep

# Common model file extensions (ignore everywhere)
*.pt
*.pth
*.onnx
*.weights
*.safetensors
*.ckpt

# ============================================================================
# Python
# ============================================================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# pipenv
Pipfile.lock

# PEP 582
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.conda/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# ============================================================================
# IDE & Editor Files
# ============================================================================
# VSCode
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~
.vim/

# Emacs
*~
\#*\#
.\#*

# ============================================================================
# OS Files
# ============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ============================================================================
# Project-Specific
# ============================================================================
# Configuration files with sensitive paths (keep template)
# Uncomment if you don't want to commit actual config
# config/pipeline.yaml
# Keep the example/template
# !config/pipeline.yaml.example

# Dashboard HTML (if you want to keep it in repo, remove this line)
# dashboard.html

# Documentation builds
docs/_build/
docs/.doctrees/

# Temporary test files
test_output/
test_data/
*.test

# Backup files
*.bak
*.backup
*.old
*.orig

# Compressed files (usually data)
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z

# Large data files
*.h5
*.hdf5
*.nc
*.netcdf

# ============================================================================
# Keep Important Directories (Empty)
# ============================================================================
# Keep directory structure but ignore contents
!artifacts/.gitkeep
!state/.gitkeep
!logs/.gitkeep
!data/.gitkeep

